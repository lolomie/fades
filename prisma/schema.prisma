generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  STARTER
  GROW
  PRO
  BUSINESS
}

enum UserRole {
  OWNER
  EMPLOYEE
  PLATFORM_ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Salon {
  id               String    @id @default(uuid())
  slug             String    @unique
  name             String
  description      String?
  phone            String?
  email            String?
  address          String?
  city             String?
  postalCode       String?
  country          String    @default("DE")
  timezone         String    @default("Europe/Berlin")
  plan             Plan      @default(STARTER)
  planExpiresAt    DateTime?
  stripeCustomerId String?
  settings         Json      @default("{}")
  users            User[]
  customers        Customer[]
  services         Service[]
  appointments     Appointment[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@map("salons")
}

model User {
  id            String    @id @default(uuid())
  salonId       String
  salon         Salon     @relation(fields: [salonId], references: [id])
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(EMPLOYEE)
  firstName     String
  lastName      String
  phone         String?
  color         String?
  isActive      Boolean   @default(true)
  refreshToken  String?
  workingHours  WorkingHour[]
  appointments  Appointment[]
  employeeServices EmployeeService[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Customer {
  id               String    @id @default(uuid())
  salonId          String
  salon            Salon     @relation(fields: [salonId], references: [id])
  email            String?
  phone            String?
  firstName        String
  lastName         String
  notes            String?
  tags             String[]  @default([])
  gdprConsent      Boolean   @default(false)
  gdprConsentDate  DateTime?
  gdprConsentIp    String?
  lastVisit        DateTime?
  visitCount       Int       @default(0)
  totalSpent       Decimal   @default(0) @db.Decimal(10, 2)
  appointments     Appointment[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@unique([salonId, email])
  @@map("customers")
}

model Service {
  id            String    @id @default(uuid())
  salonId       String
  salon         Salon     @relation(fields: [salonId], references: [id])
  name          String
  description   String?
  durationMin   Int
  bufferMin     Int       @default(0)
  price         Decimal   @db.Decimal(8, 2)
  category      String?
  color         String?
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  appointments  Appointment[]
  employeeServices EmployeeService[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("services")
}

model EmployeeService {
  userId    String
  serviceId String
  user      User    @relation(fields: [userId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([userId, serviceId])
  @@map("employee_services")
}

model WorkingHour {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  @@map("working_hours")
}

model Appointment {
  id          String            @id @default(uuid())
  salonId     String
  salon       Salon             @relation(fields: [salonId], references: [id])
  customerId  String?
  customer    Customer?         @relation(fields: [customerId], references: [id])
  employeeId  String
  employee    User              @relation(fields: [employeeId], references: [id])
  serviceId   String
  service     Service           @relation(fields: [serviceId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  status      AppointmentStatus @default(CONFIRMED)
  notes       String?
  price       Decimal           @db.Decimal(8, 2)
  cancelReason String?
  cancelledAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("appointments")
}
